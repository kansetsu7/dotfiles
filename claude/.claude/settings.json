{
  "permissions": {
    "allow": [
      "Bash(rg:*)",
      "Bash(awk:*)",
      "Bash(find:*)",
      "Bash(fd:*)",
      "Bash(git log:*)",
      "Bash(git merge-base:*)",
      "Bash(git show:*)",
      "Bash(git rev-parse:*)",
      "Bash(bundle exec ruby -I test:*)",
      "Bash(ruby -I test:*)",
      "Bash(cop master...:*)",
      "Bash(bin/rails test:*)",
      "Skill(claude-docs-consultant)",
      "Skill(commit-guide)",
      "Skill(unstuck)",
      "Skill(code-review)",
      "Skill(code-review-criteria)",
      "Read(~/.claude/skills/**)",
      "Write(.claude/**)",
      "Edit(.claude/**)",
      "mcp__gitlab__*"
    ],
    "deny": [],
    "ask": []
  },
  "model": "opus[1m]",
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/skills/knowledge-capture/hooks/detect-knowledge.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "~/.dotfiles/claude/.claude/hooks/check-file-dependencies.sh"
          },
          {
            "type": "command",
            "command": "~/.dotfiles/claude/.claude/hooks/check-credential-leak.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/scripts/statusline.sh"
  },
  "enabledPlugins": {
    "gopls-lsp@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {},
  "alwaysThinkingEnabled": true,
  "effortLevel": "xhigh",
  "autoUpdatesChannel": "latest",
  "skipDangerousModePermissionPrompt": true,
  "editorMode": "vim",
  "tui": "fullscreen",
  "env": {
    "CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY": "1"
  }
}
